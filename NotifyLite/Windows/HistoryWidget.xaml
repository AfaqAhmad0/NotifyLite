<Window x:Class="NotifyLite.Windows.HistoryWidget"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notifications"
        Width="320" SizeToContent="Height"
        MaxHeight="500"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Deactivated="Window_Deactivated"
        Loaded="Window_Loaded">

    <Border CornerRadius="12"
            Background="#1A1A2E"
            BorderBrush="#2A2A3E"
            BorderThickness="1"
            Margin="8">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.5" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <DockPanel Grid.Row="0" Margin="16,12,12,8">
                <TextBlock Text="Notifications"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="#E0E0F0"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>

                <Button x:Name="ClearAllBtn"
                        Content="Clear All"
                        FontSize="11"
                        Foreground="#888"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="8,4"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right"
                        Click="ClearAll_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2A2A3E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </DockPanel>

            <!-- Separator -->
            <Border Grid.Row="0" Height="1" Background="#2A2A3E"
                    VerticalAlignment="Bottom" Margin="12,0"/>

            <!-- Notification list -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          Margin="4,4,4,8">
                <StackPanel x:Name="NotificationList"/>
            </ScrollViewer>

            <!-- Empty state -->
            <TextBlock x:Name="EmptyText"
                       Grid.Row="1"
                       Text="No notifications"
                       FontSize="12"
                       Foreground="#555"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,30,0,30"
                       Visibility="Collapsed"/>
        </Grid>
    </Border>
</Window>
