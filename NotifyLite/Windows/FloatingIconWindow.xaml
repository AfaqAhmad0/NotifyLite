<Window x:Class="NotifyLite.Windows.FloatingIconWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NotifyLite"
        Width="44" Height="44"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Icon_MouseLeftButtonDown"
        MouseLeftButtonUp="Icon_MouseLeftButtonUp"
        Loaded="Window_Loaded">

    <Grid>
        <!-- Main icon circle -->
        <Border x:Name="IconBorder"
                Width="40" Height="40"
                CornerRadius="20"
                Cursor="Hand">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#6C63FF" Offset="0"/>
                    <GradientStop Color="#8B5CF6" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.4" Color="#000000"/>
            </Border.Effect>

            <!-- Bell icon -->
            <TextBlock Text="🔔" FontSize="18"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="0,-1,0,0"/>
        </Border>

        <!-- Notification count badge -->
        <Border x:Name="BadgeBorder"
                Width="18" Height="18"
                CornerRadius="9"
                Background="#FF3B3B"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,-2,-2,0"
                Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.3" Color="#000000"/>
            </Border.Effect>
            <TextBlock x:Name="BadgeText"
                       Text="0"
                       FontSize="9"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

        <!-- Animate-in dot (used for particle animation) -->
        <Ellipse x:Name="AnimDot"
                 Width="8" Height="8"
                 Fill="#6C63FF"
                 Opacity="0"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 IsHitTestVisible="False"/>
    </Grid>
</Window>
