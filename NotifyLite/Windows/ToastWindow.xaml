<Window x:Class="NotifyLite.Windows.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NotifyLite Toast"
        Width="300"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <!-- Slide-in + Fade-in animation -->
        <Storyboard x:Key="SlideIn">
            <DoubleAnimation Storyboard.TargetName="RootTransform"
                             Storyboard.TargetProperty="X"
                             From="320" To="0"
                             Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1"
                             Duration="0:0:0.25"/>
        </Storyboard>

        <!-- Slide-out + Fade-out animation -->
        <Storyboard x:Key="SlideOut" Completed="SlideOut_Completed">
            <DoubleAnimation Storyboard.TargetName="RootTransform"
                             Storyboard.TargetProperty="X"
                             From="0" To="320"
                             Duration="0:0:0.25">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CardBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="1" To="0"
                             Duration="0:0:0.2"/>
        </Storyboard>
    </Window.Resources>

    <!-- The toast card -->
    <Border x:Name="CardBorder"
            Margin="8"
            CornerRadius="8"
            Opacity="0"
            Cursor="Hand">
        <Border.RenderTransform>
            <TranslateTransform x:Name="RootTransform" X="320"/>
        </Border.RenderTransform>

        <!-- Drop shadow effect -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.35" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <!-- Background with theme-aware colors set in code-behind -->
            <Border x:Name="BackgroundBorder"
                    CornerRadius="8"
                    Background="#1E1E2E"
                    BorderBrush="#2A2A3E"
                    BorderThickness="1"/>

            <StackPanel Margin="12,10,12,10">
                <!-- Header: App name + close button + timestamp -->
                <DockPanel Margin="0,0,0,4">
                    <TextBlock x:Name="AppNameText"
                               Text="App Name"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="#8888AA"
                               TextTrimming="CharacterEllipsis"
                               DockPanel.Dock="Left"
                               MaxWidth="160"/>

                    <!-- Close button -->
                    <Border x:Name="CloseBtn"
                            DockPanel.Dock="Right"
                            Width="18" Height="18"
                            CornerRadius="9"
                            Background="Transparent"
                            Cursor="Hand"
                            Margin="4,0,0,0"
                            MouseLeftButtonDown="CloseBtn_Click"
                            MouseEnter="CloseBtn_MouseEnter"
                            MouseLeave="CloseBtn_MouseLeave">
                        <TextBlock Text="✕" FontSize="10" Foreground="#666688"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Name="TimestampText"
                               Text="just now"
                               FontSize="9"
                               Foreground="#666688"
                               HorizontalAlignment="Right"
                               DockPanel.Dock="Right"/>
                </DockPanel>

                <!-- Title -->
                <TextBlock x:Name="TitleText"
                           Text="Notification Title"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#E0E0F0"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="36"
                           Margin="0,0,0,2"/>

                <!-- Body -->
                <TextBlock x:Name="BodyText"
                           Text="Notification body text goes here..."
                           FontSize="11"
                           Foreground="#AAAACC"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="48"/>

                <!-- Progress bar for auto-dismiss timer -->
                <Border Margin="0,6,0,0" CornerRadius="1.5" Height="3"
                        Background="#1A1A2A" ClipToBounds="True">
                    <Border x:Name="TimerBar"
                            CornerRadius="1.5"
                            Height="3"
                            Background="#6C63FF"
                            HorizontalAlignment="Left"/>
                </Border>
            </StackPanel>
        </Grid>
    </Border>
</Window>
