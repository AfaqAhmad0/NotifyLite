<Window x:Class="NotifyLite.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NotifyLite Settings"
        Width="540" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="0" CornerRadius="0" CaptionHeight="0" ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#6C63FF"/>
            <Setter Property="Margin" Value="0,2,0,8"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Foreground" Value="#CCCCDD"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="Foreground" Value="#8B7CF6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="ValueLabel">
            <Setter Property="Foreground" Value="#9999BB"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="Margin" Value="0,6,0,2"/>
        </Style>
        <Style TargetType="TextBox" x:Key="ColorBox">
            <Setter Property="Background" Value="#2A2A3E"/>
            <Setter Property="Foreground" Value="#E0E0F0"/>
            <Setter Property="BorderBrush" Value="#3A3A4E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="4,2"/>
            <Setter Property="Width" Value="70"/>
            <Setter Property="MaxLength" Value="7"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>
    </Window.Resources>

    <Border Background="#1A1A2E" CornerRadius="10" Margin="12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="50"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Padding="16,0" MouseLeftButtonDown="Header_MouseLeftButtonDown" CornerRadius="10,10,0,0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#2A2A44" Offset="0.0"/>
                        <GradientStop Color="#1A1A2E" Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.4" Direction="270" Color="Black"/>
                </Border.Effect>
                <DockPanel>
                    <TextBlock Text="⚙️  NotifyLite Settings"
                               Foreground="#E0E0F0" FontSize="16" FontWeight="SemiBold"
                               VerticalAlignment="Center" DockPanel.Dock="Left">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.5" Color="Black"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="v2.0" Foreground="#8B7CF6" FontSize="11" FontWeight="Bold"
                               VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0"/>
                    <Button Content="✕" Width="28" Height="28" Background="Transparent" Foreground="#8B7CF6" BorderThickness="0" 
                            HorizontalAlignment="Right" VerticalAlignment="Center" DockPanel.Dock="Right" Cursor="Hand"
                            Click="CloseWin_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#2A2A44"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Scrollable Content -->
            <ScrollViewer x:Name="SettingsScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,4,28,10" PreviewMouseWheel="UIElement_OnPreviewMouseWheel">
                <StackPanel>

                    <!-- === FLOATING ICON === -->
                    <TextBlock Text="🫧  Floating Icon" Style="{StaticResource SectionHeader}" Margin="0,0,0,6"/>
                    <Border Background="#22223A" CornerRadius="12" Padding="22,16" Margin="0,0,0,12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Show floating icon on screen" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <ToggleButton x:Name="FloatingIconCheck" Style="{StaticResource FancyToggle}" VerticalAlignment="Center"
                                              HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                            </DockPanel>
                            <TextBlock Text="Draggable icon shows notification count. Click to view history."
                                       FontSize="9" Foreground="#8B7CF6" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- === APPEARANCE === -->
                    <TextBlock Text="🎨  Appearance" Style="{StaticResource SectionHeader}"/>
                    <Border Background="#22223A" CornerRadius="12" Padding="22,16" Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Theme -->
                            <DockPanel>
                                <TextBlock Text="Theme" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <ComboBox x:Name="ThemeCombo" DockPanel.Dock="Right" Width="120" HorizontalAlignment="Right" Height="28"
                                          SelectionChanged="ThemeCombo_Changed">
                                    <ComboBoxItem Content="Dark"/>
                                    <ComboBoxItem Content="Light"/>
                                </ComboBox>
                            </DockPanel>

                            <!-- Font Family -->
                            <DockPanel>
                                <TextBlock Text="Font" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <ComboBox x:Name="FontCombo" DockPanel.Dock="Right" Width="120" HorizontalAlignment="Right" Height="28">
                                    <ComboBoxItem Content="Segoe UI"/>
                                    <ComboBoxItem Content="Arial"/>
                                    <ComboBoxItem Content="Consolas"/>
                                    <ComboBoxItem Content="Cascadia Code"/>
                                    <ComboBoxItem Content="Inter"/>
                                </ComboBox>
                            </DockPanel>

                            <!-- Title size -->
                            <DockPanel>
                                <TextBlock Text="Title size" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TitleSizeLabel" Style="{StaticResource ValueLabel}" DockPanel.Dock="Right"/>
                            </DockPanel>
                            <Slider x:Name="TitleSizeSlider" Minimum="9" Maximum="20" TickFrequency="1"
                                    IsSnapToTickEnabled="True" ValueChanged="TitleSizeSlider_Changed"/>

                            <!-- Body size -->
                            <DockPanel>
                                <TextBlock Text="Body size" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="BodySizeLabel" Style="{StaticResource ValueLabel}" DockPanel.Dock="Right"/>
                            </DockPanel>
                            <Slider x:Name="BodySizeSlider" Minimum="8" Maximum="18" TickFrequency="1"
                                    IsSnapToTickEnabled="True" ValueChanged="BodySizeSlider_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- === COLORS === -->
                    <TextBlock Text="🎯  Colors" Style="{StaticResource SectionHeader}"/>
                    <Border Background="#22223A" CornerRadius="12" Padding="22,16" Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Title color -->
                            <DockPanel Margin="0,2,0,6">
                                <TextBlock Text="Title text" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                    <TextBox x:Name="TitleColorBox" Style="{StaticResource ColorBox}"
                                             TextChanged="TitleColor_Changed"/>
                                    <Border x:Name="TitleColorPreview" Width="24" Height="24" CornerRadius="4"
                                            Margin="6,0,0,0" Background="#E0E0F0"/>
                                </StackPanel>
                            </DockPanel>

                            <!-- Body color -->
                            <DockPanel Margin="0,2,0,6">
                                <TextBlock Text="Body text" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                    <TextBox x:Name="BodyColorBox" Style="{StaticResource ColorBox}"
                                             TextChanged="BodyColor_Changed"/>
                                    <Border x:Name="BodyColorPreview" Width="24" Height="24" CornerRadius="4"
                                            Margin="6,0,0,0" Background="#AAAACC"/>
                                </StackPanel>
                            </DockPanel>

                            <!-- Card background color -->
                            <DockPanel Margin="0,2,0,6">
                                <TextBlock Text="Card background" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                    <TextBox x:Name="CardColorBox" Style="{StaticResource ColorBox}"
                                             TextChanged="CardColor_Changed"/>
                                    <Border x:Name="CardColorPreview" Width="24" Height="24" CornerRadius="4"
                                            Margin="6,0,0,0" Background="#1E1E2E"/>
                                </StackPanel>
                            </DockPanel>

                            <!-- Accent color -->
                            <DockPanel Margin="0,2,0,6">
                                <TextBlock Text="Accent (timer bar)" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                                    <TextBox x:Name="AccentColorBox" Style="{StaticResource ColorBox}"
                                             TextChanged="AccentColor_Changed"/>
                                    <Border x:Name="AccentPreview" Width="24" Height="24" CornerRadius="4"
                                            Margin="6,0,0,0" Background="#6C63FF"/>
                                </StackPanel>
                            </DockPanel>
                        </StackPanel>
                    </Border>

                    <!-- === CARD === -->
                    <TextBlock Text="📐  Card" Style="{StaticResource SectionHeader}"/>
                    <Border Background="#22223A" CornerRadius="12" Padding="22,16" Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Width -->
                            <DockPanel>
                                <TextBlock Text="Width" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="WidthLabel" Style="{StaticResource ValueLabel}" DockPanel.Dock="Right"/>
                            </DockPanel>
                            <Slider x:Name="WidthSlider" Minimum="240" Maximum="500" TickFrequency="10"
                                    IsSnapToTickEnabled="True" ValueChanged="WidthSlider_Changed"/>

                            <!-- Corner Radius -->
                            <DockPanel>
                                <TextBlock Text="Corner radius" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="RadiusLabel" Style="{StaticResource ValueLabel}" DockPanel.Dock="Right"/>
                            </DockPanel>
                            <Slider x:Name="RadiusSlider" Minimum="0" Maximum="20" TickFrequency="1"
                                    IsSnapToTickEnabled="True" ValueChanged="RadiusSlider_Changed"/>

                            <!-- Card Opacity -->
                            <DockPanel>
                                <TextBlock Text="Card opacity" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="CardOpacityLabel" Style="{StaticResource ValueLabel}" DockPanel.Dock="Right"/>
                            </DockPanel>
                            <Slider x:Name="CardOpacitySlider" Minimum="0.2" Maximum="1.0" TickFrequency="0.05"
                                    IsSnapToTickEnabled="True" ValueChanged="CardOpacitySlider_Changed"/>

                            <!-- Text Opacity -->
                            <DockPanel>
                                <TextBlock Text="Text opacity" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="TextOpacityLabel" Style="{StaticResource ValueLabel}" DockPanel.Dock="Right"/>
                            </DockPanel>
                            <Slider x:Name="TextOpacitySlider" Minimum="0.3" Maximum="1.0" TickFrequency="0.05"
                                    IsSnapToTickEnabled="True" ValueChanged="TextOpacitySlider_Changed"/>
                        </StackPanel>
                    </Border>

                    <!-- === BEHAVIOR === -->
                    <TextBlock Text="⏱️  Behavior" Style="{StaticResource SectionHeader}"/>
                    <Border Background="#22223A" CornerRadius="12" Padding="22,16" Margin="0,0,0,12">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="Auto-dismiss" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="DurationLabel" Style="{StaticResource ValueLabel}" DockPanel.Dock="Right"/>
                            </DockPanel>
                            <Slider x:Name="DurationSlider" Minimum="2" Maximum="15" TickFrequency="0.5"
                                    IsSnapToTickEnabled="True" ValueChanged="DurationSlider_Changed"/>

                            <DockPanel>
                                <TextBlock Text="Max visible toasts" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <TextBlock x:Name="MaxToastsLabel" Style="{StaticResource ValueLabel}" DockPanel.Dock="Right"/>
                            </DockPanel>
                            <Slider x:Name="MaxToastsSlider" Minimum="1" Maximum="10" TickFrequency="1"
                                    IsSnapToTickEnabled="True" ValueChanged="MaxToastsSlider_Changed"/>

                            <DockPanel>
                                <TextBlock Text="Position" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <ComboBox x:Name="PositionCombo" DockPanel.Dock="Right" Width="120" HorizontalAlignment="Right" Height="28"
                                          SelectionChanged="PositionCombo_Changed">
                                    <ComboBoxItem Content="Bottom Right" Tag="BottomRight"/>
                                    <ComboBoxItem Content="Bottom Left" Tag="BottomLeft"/>
                                    <ComboBoxItem Content="Top Right" Tag="TopRight"/>
                                    <ComboBoxItem Content="Top Left" Tag="TopLeft"/>
                                    <ComboBoxItem Content="Stick to Icon" Tag="FloatingIcon"/>
                                    <ComboBoxItem Content="Custom" Tag="Custom"/>
                                </ComboBox>
                            </DockPanel>

                            <!-- Custom position X/Y (only visible when Custom selected) -->
                            <StackPanel x:Name="CustomPositionPanel" Visibility="Collapsed" Margin="0,4,0,0">
                                <DockPanel Margin="0,2,0,4">
                                    <TextBlock Text="X position" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                    <TextBox x:Name="PosXBox" Width="70" HorizontalAlignment="Right" DockPanel.Dock="Right"
                                             Background="#2A2A3E" Foreground="#E0E0F0" BorderBrush="#3A3A4E"
                                             Padding="4,2" FontSize="11"/>
                                </DockPanel>
                                <DockPanel Margin="0,2,0,4">
                                    <TextBlock Text="Y position" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                    <TextBox x:Name="PosYBox" Width="70" HorizontalAlignment="Right" DockPanel.Dock="Right"
                                             Background="#2A2A3E" Foreground="#E0E0F0" BorderBrush="#3A3A4E"
                                             Padding="4,2" FontSize="11"/>
                                </DockPanel>
                                <TextBlock x:Name="PositionTipText" Text="Tip: Min 0. Max X: screen width, Max Y: screen height" FontSize="9" Foreground="#555" Margin="0,0,0,4"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>



                    <!-- === SOUND === -->
                    <TextBlock Text="🔔  Sound" Style="{StaticResource SectionHeader}"/>
                    <Border Background="#22223A" CornerRadius="12" Padding="22,16" Margin="0,0,0,12">
                        <StackPanel>
                            <!-- Global sound toggle -->
                            <DockPanel>
                                <TextBlock Text="Notification sound" Style="{StaticResource Label}" DockPanel.Dock="Left"/>
                                <ToggleButton x:Name="SoundEnabledCheck" Style="{StaticResource FancyToggle}" VerticalAlignment="Center"
                                              HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                            </DockPanel>

                            <!-- Default vs Custom -->
                            <TextBlock Text="Default sound" Style="{StaticResource Label}"/>
                            <DockPanel Margin="0,2,0,6">
                                <RadioButton x:Name="DefaultSoundRadio" Content="System default"
                                             Foreground="#CCCCDD" GroupName="SoundType" VerticalAlignment="Center"
                                             DockPanel.Dock="Left" Checked="SoundType_Changed"/>
                                <RadioButton x:Name="CustomSoundRadio" Content="Custom"
                                             Foreground="#CCCCDD" GroupName="SoundType" VerticalAlignment="Center"
                                             DockPanel.Dock="Left" Margin="20,0,0,0" Checked="SoundType_Changed"/>
                            </DockPanel>

                            <!-- Custom sound file (visible when Custom selected) -->
                            <DockPanel x:Name="CustomSoundPanel" Margin="0,0,0,6">
                                <Button Content="Browse..." Width="70" Height="24"
                                        HorizontalAlignment="Right" DockPanel.Dock="Right"
                                        Click="BrowseSound_Click"/>
                                <TextBox x:Name="SoundFileBox" IsReadOnly="True" Margin="0,0,6,0"
                                         Background="#2A2A3E" Foreground="#E0E0F0" BorderBrush="#3A3A4E"
                                         Padding="4,2" FontSize="10"/>
                            </DockPanel>

                            <!-- Per-app sounds -->
                            <TextBlock Text="Per-app sound overrides" Style="{StaticResource Label}" Margin="0,8,0,4"/>
                            <Border Background="#1A1A2A" CornerRadius="4" Padding="8,4" MaxHeight="180">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseWheel="UIElement_OnPreviewMouseWheel">
                                    <StackPanel x:Name="AppSoundsPanel"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#16162A" Padding="16,0">
                <DockPanel>
                    <Button Content="Reset Defaults" Width="110" Height="30"
                            DockPanel.Dock="Left" Click="Reset_Click"
                            Background="#2A2A3E" Foreground="#AAAACC" BorderBrush="#3A3A4E"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancel" Width="80" Height="30"
                                Click="Cancel_Click" Margin="0,0,8,0"
                                Background="#2A2A3E" Foreground="#AAAACC" BorderBrush="#3A3A4E"/>
                        <Button Content="Save" Width="80" Height="30"
                                Click="Save_Click"
                                Background="#6C63FF" Foreground="White" BorderBrush="#5A53EE" FontWeight="SemiBold"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>
    </Border>
</Window>
